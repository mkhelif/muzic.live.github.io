BEGIN:VCALENDAR
VERSION:2.0
{{ $title := printf "%s | %s" site.Title .LinkTitle -}}
PRODID:-//{{ $title }}//NONSGML v1.0//EN
X-WR-CALNAME:{{ $title }}
NAME:{{ $title }}
REFRESH-INTERVAL;VALUE=DURATION:P3H
CALSCALE:GREGORIAN
{{ if eq .Section "artists" -}}
    {{- partial "artists/events.ics" . -}}
{{- else if eq .Section "locations" -}}
    {{- partial "locations/events.ics" . -}}
{{- end -}}
END:VCALENDAR{{- /**/ -}}
