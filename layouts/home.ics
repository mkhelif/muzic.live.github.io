BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//{{ site.Title }}//NONSGML v1.0//EN
X-WR-CALNAME:{{ site.Title }}
NAME:{{ site.Title }}
REFRESH-INTERVAL;VALUE=DURATION:P3H
CALSCALE:GREGORIAN
{{ partial "calendar/events.ics" (dict "page" . "events" (where site.RegularPages "Section" "events")) }}
END:VCALENDAR
