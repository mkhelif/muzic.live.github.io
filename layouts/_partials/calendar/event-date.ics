{{- $format := "20060102T150405Z" -}}
{{ $eventDate := .Date | time.AsTime -}}
DTSTAMP:{{ ($eventDate | time.In "UTC") | time.Format $format }}
DTSTART:{{ ($eventDate | time.In "UTC") | time.Format $format }}
{{ $artistsCount := 0 -}}
{{ with .Params.artists }}{{ $artistsCount = len . }}{{ end -}}
{{ $duration := time.ParseDuration (printf "%dh" $artistsCount) -}}
DTEND:{{ (($eventDate.Add $duration) | time.In "UTC") | time.Format $format }}
{{- /**/ -}}
