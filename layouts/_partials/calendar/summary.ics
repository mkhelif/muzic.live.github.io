{{- if eq .page.Section "artists" -}}
    {{ .page.Title }} : {{- partial "calendar/event-location.ics" .event.Params.locationId }}
{{- else if eq .page.Section "festivals" -}}
    {{ .page.Title }} : {{ partial "calendar/artists.ics" .event }}
{{- else if eq .page.Section "locations" -}}
    {{ .page.Title }} : {{ partial "calendar/artists.ics" .event }}
{{- else if eq .page.Section "home" -}}
    {{ .page.Title }} ({{ partial "calendar/event-location.ics" .event.Params.locationId }})
{{- end -}}

