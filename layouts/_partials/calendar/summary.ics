{{- if .page.IsHome -}}
    {{ partial "calendar/event-artists.ics" .event.Params.artists }} ({{ partial "calendar/event-location.ics" .event.Params.locationId }})
{{- else if eq .page.Section "artists" -}}
    {{ .page.Title }} : {{ partial "calendar/event-location.ics" .event.Params.locationId }}
{{- else if eq .page.Section "locations" -}}
    {{ .page.Title }} : {{ partial "calendar/event-artists.ics" .event.Params.artists }}
{{- else if eq .page.Section "home" -}}
    {{ .page.Title }} ({{ partial "calendar/event-location.ics" .event.Params.locationId }})
{{- end -}}
