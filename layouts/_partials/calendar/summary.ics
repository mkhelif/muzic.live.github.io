{{- if .page.IsHome -}}
    {{ partial "calendar/event-artists.ics" .event.Params.artists }} ({{ partial "calendar/event-venue.ics" .event.Params.venue }})
{{- else if eq .page.Section "artists" -}}
    {{ .page.Title }} : {{ partial "calendar/event-venue.ics" .event.Params.venue }}
{{- else if eq .page.Section "venues" -}}
    {{ .page.Title }} : {{ partial "calendar/event-artists.ics" .event.Params.artists }}
{{- else if eq .page.Section "home" -}}
    {{ .page.Title }} ({{ partial "calendar/event-venue.ics" .event.Params.venue }})
{{- end -}}
