BEGIN:VEVENT
UID:{{ hash.XxHash .event.RelPermalink }}
{{ partial "calendar/event-date.ics" .event }}
SUMMARY:{{ partial "calendar/summary.ics" . }}
DESCRIPTION:{{ partial "calendar/event-artists.ics" .event.Params.artists }}
LOCATION:{{ replace (partial "calendar/venue.ics" .event.Params.venue) "," "\\," }}
{{ partial "calendar/event-geo.ics" .event.Params.venue }}
BEGIN:VALARM
TRIGGER:-P15D
DESCRIPTION:{{ partial "calendar/summary.ics" . }}
ACTION:DISPLAY
END:VALARM
{{ partialCached "calendar/apple.ics" . }}
{{ partialCached "calendar/outlook.ics" . }}
END:VEVENT
{{- /**/ -}}
