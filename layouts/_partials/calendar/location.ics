{{- $locationId := . -}}
{{- range hugo.Sites -}}
    {{- range where (where .Pages ".Section" "locations") ".Params.id" $locationId -}}
        {{- .LinkTitle -}}
        {{- if .Params.address -}}
            , {{ .Params.address -}}
        {{- else if .Params.locationId -}}
            , {{ partial "calendar/location.ics" .Params.locationId -}}
        {{- end -}}
    {{- end -}}
{{- end -}}
